                "RawHtml": {
                  "Content": {
                    "Html": "<section class=\"icf-section icf-section-light\"><div class=\"container\"><div class=\"row mb-4\"><div class=\"col-lg-8\"><span class=\"icf-hero-eyebrow\">Prije i poslije</span><h2>Od starih problema do ugodnog, učinkovitog doma.</h2></div></div><div class=\"icf-ba\"><div class=\"icf-ba-col icf-ba-before\"><h3>Klasična gradnja</h3><ul><li>Visoki troškovi grijanja i hlađenja</li><li>Toplinski mostovi i propuh</li><li>Izolacija naknadno, u više faza</li><li>Dugi rokovi izvedbe</li></ul></div><div class=\"icf-ba-bridge\"><span>VHG ICF sustav</span></div><div class=\"icf-ba-col icf-ba-after\"><h3>VHG ICF dom</h3><ul><li>Do 70% niža potrošnja energije</li><li>Bez toplinskih mostova, ugodna temperatura</li><li>Konstrukcija i izolacija u jednoj fazi</li><li>Brza gruba konstrukcija — u tjednima</li></ul></div></div><div class=\"text-center mt-4\"><a href=\"/kontakt\" class=\"btn btn-icf-primary\">Izračunajte svoju uštedu</a></div></div></section>"
                  }
