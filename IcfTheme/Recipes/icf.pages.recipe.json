                  "Content": {
                    "Html": "<section class=\"icf-section\"><div class=\"container\"><div class=\"row mb-4\"><div class=\"col-lg-8\"><span class=\"icf-hero-eyebrow\">Zvuči poznato?</span><h2>Gradnja ne bi smjela značiti visoke račune i neizvjesnost.</h2></div></div><div class=\"icf-pain-grid\"><div class=\"icf-pain\"><i class=\"fas fa-fire\"></i><div><strong>Visoki troškovi grijanja</strong><span>Računi rastu iz godine u godinu.</span></div></div><div class=\"icf-pain\"><i class=\"fas fa-temperature-low\"></i><div><strong>Hladne zime, vruća ljeta</strong><span>Loša izolacija i toplinski mostovi.</span></div></div><div class=\"icf-pain\"><i class=\"fas fa-head-side-cough\"></i><div><strong>Buka i vlaga</strong><span>Nelagodan boravak i rizik od plijesni.</span></div></div><div class=\"icf-pain\"><i class=\"fas fa-hourglass-half\"></i><div><strong>Spora, nesigurna gradnja</strong><span>Dugi rokovi i nepredvidivi troškovi.</span></div></div></div></div></section>"
                  }
                }
