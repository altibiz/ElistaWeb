                "RawHtml": {
                  "Content": {
                    "Html": "<section class=\"icf-section icf-section-light\"><div class=\"container\"><div class=\"row mb-5\"><div class=\"col-lg-8\"><span class=\"icf-hero-eyebrow\">Za koga gradimo</span><h2>Rješenje prilagođeno vašem cilju.</h2></div></div><div class=\"row g-4\"><div class=\"col-md-4\"><div class=\"icf-option-card\"><div class=\"icf-option-icon\"><i class=\"fas fa-home\"></i></div><h3>Obitelji</h3><p><strong>Želite:</strong> topao, siguran i zdrav dom uz niske troškove.<br /><strong>Dobivate:</strong> ugodnu temperaturu cijele godine i do 70% niže račune.</p><a href=\"/kontakt\" class=\"btn btn-icf-outline\">Zatražite procjenu</a></div></div><div class=\"col-md-4\"><div class=\"icf-option-card\"><div class=\"icf-option-icon\"><i class=\"fas fa-chart-line\"></i></div><h3>Investitori</h3><p><strong>Želite:</strong> nisku operativnu potrošnju i očuvanje vrijednosti.<br /><strong>Dobivate:</strong> energetski razred A+ i dugotrajnu masivnu konstrukciju.</p><a href=\"/kontakt\" class=\"btn btn-icf-outline\">Zatražite ponudu</a></div></div><div class=\"col-md-4\"><div class=\"icf-option-card\"><div class=\"icf-option-icon\"><i class=\"fas fa-building\"></i></div><h3>Poslovni objekti</h3><p><strong>Želite:</strong> brzu gradnju i sigurnost u planiranju.<br /><strong>Dobivate:</strong> kratke rokove, predvidive troškove i certificiran sustav.</p><a href=\"/kontakt\" class=\"btn btn-icf-outline\">Razgovarajmo</a></div></div></div></div></section>"
                  }
                }
