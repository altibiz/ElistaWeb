          "ContentItemId": "icfpgfaq000000000000000000",
          "ContentType": "Page",
          "DisplayText": "Česta pitanja",
          "Latest": true,
          "Published": true,
          "Author": "admin",
          "Page": {},
          "TitlePart": { "Title": "Česta pitanja" },
          "AutoroutePart": {
            "Path": "cesta-pitanja",
            "SetHomepage": false,
            "Disabled": false,
            "RouteContainedItems": false,
            "Absolute": false
